{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@app/*": ["src/app/*"],
      "@assets/*": ["src/assets/*"],
      "@environments/*": ["src/environments/*"],
      "@utils/*": ["src/utils/*"],
      "@shared/*": ["src/app/shared/*"],
      "@services/*": ["src/app/services/*"],
      "@modules/*": ["src/app/modules/*"],
      "@pages/*": ["src/app/pages/*"],
      "@interceptors/*": ["src/app/interceptors/*"],
      "@fake/*": ["src/app/_fake/*"],
      "@metronic/*": ["src/app/_metronic/*"]
    }
  }
}
